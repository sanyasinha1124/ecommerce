{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
     "strictPropertyInitialization": false, 
     "forceConsistentCasingInFileNames": true,
     "types": ["node"],          // 👈 add this
   

  },
  "include": ["src/**/*", "src/server.ts"],
  "exclude": ["node_modules", "dist"]
}