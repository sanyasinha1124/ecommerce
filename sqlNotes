joins 

multiple joins -
SELECT 
    e.event_id,
    e.event_name,
    c.category_name,
    u.user_name AS organizer_name,
    COUNT(b.booking_id) AS total_tickets_sold
FROM Events e
INNER JOIN Categories c ON e.category_id = c.category_id
INNER JOIN Users u ON e.organizer_id = u.user_id
LEFT JOIN Bookings b ON e.event_id = b.event_id
GROUP BY e.event_id, e.event_name, c.category_name, u.user_name;
