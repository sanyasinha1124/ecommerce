multiple try catch 

BEGIN TRANSACTION;
BEGIN TRY
    -- Step 1: Critical Core Logic
    INSERT INTO Orders (OrderID, Date) VALUES (1, GETDATE());

    BEGIN TRY
        -- Step 2: Non-critical (e.g., Logging)
        INSERT INTO AuditLog (Message) VALUES ('Order placed');
    END TRY
    BEGIN CATCH
        -- Swallow error or log it, but don't kill the main transaction
        PRINT 'Logging failed, but moving on...';
    END CATCH

    COMMIT TRANSACTION;
END TRY
BEGIN CATCH
    IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
    THROW; -- Re-throw the error to the calling application
END CATCH
